<%- include('partials/header') %>
<%- include('partials/nav') %>
<%- include('partials/hero') %>

<%
  const getInitials = (prenom, nom) => `${(prenom||'')[0]||''}${(nom||'')[0]||''}`.toUpperCase();
  const fmt = (d) => d ? new Date(d).toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric' }) : '—';

  // Durée lisible entre deux dates
  const duration = (start, end) => {
    if (!start || !end) return null;
    const ms  = new Date(end) - new Date(start);
    const days = Math.round(ms / 86400000);
    if (days < 1) return "moins d'un jour";
    if (days < 30) return `${days} jour${days>1?'s':''}`;
    const months = Math.floor(days / 30);
    if (months < 12) return `${months} mois`;
    const years = Math.floor(months / 12);
    const rem   = months % 12;
    return rem > 0 ? `${years} an${years>1?'s':''} et ${rem} mois` : `${years} an${years>1?'s':''}`;
  };
%>

<div class="history-page">
  <!-- Hero Section -->
  <div class="history-hero">
    <div class="hero-glow-history"></div>
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-icon">📜</span>
        <span class="badge-text">Archives & Mémoire</span>
        <span class="badge-icon">📜</span>
      </div>
      <h1 class="hero-title">
        <span class="title-line">Historique des </span>
        <span class="title-line title-accent-gold">Anciennes Blacklists</span>
      </h1>
      <p class="hero-description">
        Retrouvez toutes les personnes ayant déjà été blacklistées au Diamond Casino.
      </p>

      <div class="hero-stats">
        <div class="stat-card">
          <div class="stat-icon">📋</div>
          <div class="stat-content">
            <span class="stat-label">Entrées archivées</span>
            <span class="stat-value"><%= items.length %></span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🗑️</div>
          <div class="stat-content">
            <span class="stat-label">Supprimées manuellement</span>
            <span class="stat-value"><%= items.filter(i => i.removalType === 'manual').length %></span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">⏰</div>
          <div class="stat-content">
            <span class="stat-label">Expirées</span>
            <span class="stat-value"><%= items.filter(i => i.removalType === 'expired').length %></span>
          </div>
        </div>
      </div>

      <a href="/blacklist" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Retour à la Blacklist active
      </a>
    </div>
  </div>

  <div class="history-container">

    <!-- Search Bar -->
    <div class="search-section">
      <div class="search-wrapper">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <input type="text" id="searchInput" class="search-input" placeholder="Rechercher par nom ou prénom..." />
      </div>
    </div>

    <% if (items.length === 0) { %>
      <div class="empty-state-modern">
        <div class="empty-icon">📭</div>
        <h3>Aucun historique enregistré</h3>
        <p>Les blacklists supprimées ou expirées apparaîtront ici automatiquement.</p>
      </div>
    <% } else { %>
      <div class="section-header">
        <h2 class="section-title">Toutes les anciennes interdictions</h2>
        <span class="blacklist-count" id="count"><%= items.length %> entrée<%= items.length > 1 ? 's' : '' %></span>
      </div>

      <div class="history-grid" id="historyContainer">
        <% items.forEach((item) => { %>
          <%
            const dur = duration(item.addedAt, item.removedAt);
          %>
          <article class="history-card" data-nom="<%= (item.nom||'').toLowerCase() %>" data-prenom="<%= (item.prenom||'').toLowerCase() %>">
            <div class="hcard-left">
              <div class="h-avatar">
                <% if (item.photoUrl) { %>
                  <img src="<%= item.photoUrl %>" alt="<%= item.prenom %> <%= item.nom %>" class="avatar-img" />
                <% } else { %>
                  <span class="avatar-text"><%= getInitials(item.prenom, item.nom) %></span>
                <% } %>
              </div>
            </div>

            <div class="hcard-body">
              <div class="hcard-top">
                <span class="h-name"><%= item.prenom %> <%= item.nom %></span>
                <span class="removal-badge <%= item.removalType === 'expired' ? 'badge-expired' : 'badge-manual' %>">
                  <%= item.removalType === 'expired' ? '⏰ Expirée' : '🗑️ Supprimée' %>
                </span>
              </div>

              <% if (item.raison) { %>
                <p class="h-raison">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                  </svg>
                  <%= item.raison %>
                </p>
              <% } else { %>
                <p class="h-raison h-raison-empty">Aucune raison spécifiée</p>
              <% } %>

              <div class="h-meta-row">
                <div class="h-meta-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <span>Ajouté le <strong><%= fmt(item.addedAt) %></strong></span>
                </div>
                <div class="h-meta-item">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                  <span>Retiré le <strong><%= fmt(item.removedAt) %></strong></span>
                </div>
                <% if (dur) { %>
                  <div class="h-meta-item h-meta-duration">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 2v10l4 4"></path>
                      <circle cx="12" cy="12" r="10"></circle>
                    </svg>
                    <span>Durée : <strong><%= dur %></strong></span>
                  </div>
                <% } %>
                <% if (!item.permanent && item.expireAt) { %>
                  <div class="h-meta-item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span>Prévue jusqu'au <strong><%= fmt(item.expireAt) %></strong></span>
                  </div>
                <% } else if (item.permanent) { %>
                  <div class="h-meta-item">
                    <span>♾️ Était permanente</span>
                  </div>
                <% } %>
              </div>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<!-- Search JS -->
<script>
  const input = document.getElementById('searchInput');
  const cards = document.querySelectorAll('.history-card');
  const countEl = document.getElementById('count');
  const total = cards.length;

  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      cards.forEach(card => {
        const match = (card.dataset.nom || '').includes(q) || (card.dataset.prenom || '').includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (countEl) countEl.textContent = `${visible} entrée${visible > 1 ? 's' : ''}`;
    });
  }
</script>

<style>
  .history-page {
    min-height: 100vh;
    padding-bottom: 80px;
    background: #000;
  }

  /* ===== HERO ===== */
  .history-hero {
    position: relative;
    padding: 100px 20px 80px;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow-history {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(212,175,55,0.07) 0%, transparent 70%);
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.3; }
    50%       { transform: translateX(-50%) scale(1.05); opacity: 0.5; }
  }

  .title-accent-gold {
    background: linear-gradient(135deg, #d4af37, #f5d778, #d4af37);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 10px 22px;
    background: rgba(212,175,55,0.1);
    border: 1px solid rgba(212,175,55,0.4);
    border-radius: 50px;
    color: #d4af37;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .back-btn:hover {
    background: rgba(212,175,55,0.2);
    border-color: #d4af37;
  }

  /* ===== CONTAINER ===== */
  .history-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ===== SEARCH ===== */
  .search-section { margin-bottom: 32px; }
  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    color: rgba(255,255,255,0.3);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 14px 20px 14px 50px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    color: #fff;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus { border-color: rgba(212,175,55,0.5); }
  .search-input::placeholder { color: rgba(255,255,255,0.3); }

  /* ===== SECTION HEADER ===== */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .section-title { color: #fff; font-size: 1.4rem; font-weight: 600; }
  .blacklist-count {
    padding: 6px 14px;
    background: rgba(212,175,55,0.15);
    border: 1px solid rgba(212,175,55,0.3);
    border-radius: 20px;
    color: #d4af37;
    font-size: 0.85rem;
  }

  /* ===== GRID ===== */
  .history-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ===== CARD ===== */
  .history-card {
    display: flex;
    gap: 20px;
    padding: 20px 24px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(212,175,55,0.15);
    border-radius: 16px;
    transition: border-color 0.2s, background 0.2s;
  }
  .history-card:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(212,175,55,0.35);
  }

  /* Avatar */
  .hcard-left { flex-shrink: 0; }
  .h-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(212,175,55,0.2), rgba(212,175,55,0.05));
    border: 2px solid rgba(212,175,55,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .h-avatar .avatar-img  { width: 100%; height: 100%; object-fit: cover; }
  .h-avatar .avatar-text { color: #d4af37; font-weight: 700; font-size: 1.1rem; }

  /* Body */
  .hcard-body { flex: 1; min-width: 0; }

  .hcard-top {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .h-name {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
  }

  /* Badges */
  .removal-badge {
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .badge-expired {
    background: rgba(255,165,0,0.15);
    border: 1px solid rgba(255,165,0,0.4);
    color: #ffa500;
  }
  .badge-manual {
    background: rgba(255,59,82,0.12);
    border: 1px solid rgba(255,59,82,0.35);
    color: #ff3b52;
  }

  /* Raison */
  .h-raison {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    margin-bottom: 10px;
    line-height: 1.5;
  }
  .h-raison svg { flex-shrink: 0; margin-top: 2px; opacity: 0.6; }
  .h-raison-empty { color: rgba(255,255,255,0.3); font-style: italic; }

  /* Meta row */
  .h-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
  }
  .h-meta-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
  }
  .h-meta-item svg { opacity: 0.5; flex-shrink: 0; }
  .h-meta-item strong { color: rgba(255,255,255,0.8); }
  .h-meta-duration { color: rgba(212,175,55,0.8); }
  .h-meta-duration svg { opacity: 0.8; }
  .h-meta-duration strong { color: #d4af37; }

  /* ===== EMPTY STATE ===== */
  .empty-state-modern {
    text-align: center;
    padding: 80px 20px;
    color: rgba(255,255,255,0.4);
  }
  .empty-icon { font-size: 4rem; margin-bottom: 16px; }
  .empty-state-modern h3 { color: rgba(255,255,255,0.7); font-size: 1.3rem; margin-bottom: 8px; }

  @media (max-width: 600px) {
    .history-card { flex-direction: column; gap: 12px; }
    .h-avatar { width: 48px; height: 48px; }
  }
</style>

<%- include('partials/footer') %>
