<%- include('partials/header') %>
<%- include('partials/nav') %>
<%- include('partials/hero') %>

<% const pendingCount = (items || []).filter(i => !i.isCompleted).length; %>
<% const completedCount = (items || []).filter(i => i.isCompleted).length; %>
<% const formatDate = (d) => d ? new Date(d).toLocaleDateString('fr-FR') : '—'; %>
<% const getInitials = (prenom, nom) => `${prenom[0] || ''}${nom[0] || ''}`.toUpperCase(); %>

<div class="container ems-page">
  <section class="ems-hero">
    <div>
      <h1>🩺 Thérapie EMS</h1>
      <p>Suivi des personnes devant passer une thérapie EMS après comportement inapproprié.</p>
    </div>
    <div class="ems-stats">
      <span class="chip chip--pending">À faire: <b><%= pendingCount %></b></span>
      <span class="chip chip--done">Terminées: <b><%= completedCount %></b></span>
    </div>
  </section>

  <section class="ems-search">
    <input type="text" id="searchInput" placeholder="Rechercher par nom/prénom..." />
    <span id="count" class="muted"><%= items.length %> personne(s)</span>
  </section>

  <% if (user) { %>
    <section class="ems-form">
      <h3>Ajouter une personne à suivre</h3>
      <form method="post" action="/therapie-ems" enctype="multipart/form-data">
        <% if (authToken) { %>
          <input type="hidden" name="token" value="<%= authToken %>" />
        <% } %>
        <div class="row">
          <input name="prenom" placeholder="Prénom" required />
          <input name="nom" placeholder="Nom" required />
        </div>
        <textarea name="raison" rows="3" placeholder="Motif / contexte"></textarea>
        <div class="row">
          <input name="photoUrl" placeholder="URL photo (optionnel)" />
          <input name="photo" type="file" accept="image/*" />
        </div>
        <button class="btn btn-add" type="submit">Ajouter au suivi EMS</button>
      </form>
    </section>
  <% } %>

  <section>
    <h3>Liste de suivi EMS</h3>
    <% if (items.length === 0) { %>
      <p class="empty-state">Aucun suivi EMS en cours.</p>
    <% } else { %>
      <div class="ems-grid" id="emsGrid">
        <% items.forEach((item) => { %>
          <article class="ems-card <%= item.isCompleted ? 'ems-card--done' : 'ems-card--pending' %>" data-nom="<%= (item.nom || '').toLowerCase() %>" data-prenom="<%= (item.prenom || '').toLowerCase() %>">
            <div class="ems-card__top">
              <div class="identity">
                <div class="avatar">
                  <% if (item.photoUrl) { %>
                    <img src="<%= item.photoUrl %>" alt="<%= item.prenom %> <%= item.nom %>" />
                  <% } else { %>
                    <span><%= getInitials(item.prenom || 'X', item.nom || 'X') %></span>
                  <% } %>
                </div>
                <div>
                  <h4><%= item.prenom %> <%= item.nom %></h4>
                  <p class="muted">Ajouté le <%= formatDate(item.createdAt) %></p>
                </div>
              </div>
              <span class="state <%= item.isCompleted ? 'state--done' : 'state--pending' %>">
                <%= item.isCompleted ? 'Thérapie faite' : 'En attente EMS' %>
              </span>
            </div>

            <% if (item.raison) { %>
              <p class="reason">📝 <%= item.raison %></p>
            <% } %>

            <% if (item.isCompleted && item.completedAt) { %>
              <p class="muted">✅ Validé le <%= formatDate(item.completedAt) %></p>
            <% } %>

            <% if (user) { %>
              <div class="ems-actions">
                <form method="post" action="/therapie-ems/<%= item._id %>/toggle-completed">
                  <% if (authToken) { %>
                    <input type="hidden" name="token" value="<%= authToken %>" />
                  <% } %>
                  <label class="checkbox-inline">
                    <input type="checkbox" name="isCompleted" value="true" <%= item.isCompleted ? 'checked' : '' %> onchange="this.form.submit()" />
                    Thérapie effectuée
                  </label>
                </form>

                <button class="btn-edit" type="button" data-edit="<%= item._id %>">Modifier</button>

                <form method="post" action="/therapie-ems/<%= item._id %>/delete">
                  <% if (authToken) { %>
                    <input type="hidden" name="token" value="<%= authToken %>" />
                  <% } %>
                  <button class="btn-delete" type="submit" onclick="return confirm('Supprimer cette entrée EMS ?')">Supprimer</button>
                </form>
              </div>

              <div class="edit-form" data-edit-form="<%= item._id %>">
                <form method="post" action="/therapie-ems/<%= item._id %>/update" enctype="multipart/form-data">
                  <% if (authToken) { %>
                    <input type="hidden" name="token" value="<%= authToken %>" />
                  <% } %>
                  <div class="row">
                    <input name="prenom" value="<%= item.prenom %>" required />
                    <input name="nom" value="<%= item.nom %>" required />
                  </div>
                  <textarea name="raison" rows="2"><%= item.raison || '' %></textarea>
                  <div class="row">
                    <input name="photoUrl" value="<%= item.photoUrl || '' %>" placeholder="URL photo" />
                    <input name="photo" type="file" accept="image/*" />
                  </div>
                  <button class="btn btn-add" type="submit">Enregistrer</button>
                </form>
              </div>
            <% } %>
          </article>
        <% }); %>
      </div>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>

<style>
.ems-page {
  display: grid;
  gap: 24px;
}

.ems-hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  padding: 24px;
  border-radius: 16px;
  border: 1px solid rgba(16, 185, 129, 0.3);
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(0, 0, 0, 0.35));
}

.ems-hero h1 {
  margin: 0 0 6px;
  color: #34d399;
}

.ems-hero p {
  margin: 0;
  color: rgba(255, 255, 255, 0.7);
}

.ems-stats {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.chip {
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.chip--pending {
  background: rgba(251, 191, 36, 0.2);
  color: #fbbf24;
}

.chip--done {
  background: rgba(16, 185, 129, 0.2);
  color: #34d399;
}

.ems-search {
  display: flex;
  gap: 10px;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
}

.ems-search input {
  min-width: 280px;
  flex: 1;
}

.ems-form {
  padding: 20px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
}

.ems-form h3 {
  margin: 0 0 14px;
  color: #60a5fa;
}

.ems-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 14px;
}

.ems-card {
  padding: 16px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
}

.ems-card--pending {
  border-color: rgba(251, 191, 36, 0.35);
}

.ems-card--done {
  border-color: rgba(16, 185, 129, 0.35);
  opacity: 0.92;
}

.ems-card__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.identity {
  display: flex;
  align-items: center;
  gap: 10px;
}

.avatar {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  overflow: hidden;
  display: grid;
  place-items: center;
  background: rgba(96, 165, 250, 0.18);
}

.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar span {
  font-weight: 700;
}

.identity h4 {
  margin: 0;
}

.state {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 999px;
}

.state--pending {
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.18);
}

.state--done {
  color: #34d399;
  background: rgba(16, 185, 129, 0.18);
}

.reason {
  margin: 12px 0;
  color: rgba(255, 255, 255, 0.82);
}

.ems-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  margin-top: 12px;
}

.checkbox-inline {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
}

.btn-edit,
.btn-delete {
  border: none;
  border-radius: 8px;
  padding: 8px 10px;
  cursor: pointer;
}

.btn-edit {
  background: rgba(59, 130, 246, 0.2);
  color: #60a5fa;
}

.btn-delete {
  background: rgba(239, 68, 68, 0.2);
  color: #f87171;
}

.edit-form {
  display: none;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.edit-form.is-open {
  display: block;
}

@media (max-width: 720px) {
  .ems-hero {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>

<script>
// Search by name
const searchInput = document.getElementById('searchInput');
if (searchInput) {
  searchInput.addEventListener('input', function() {
    const term = this.value.toLowerCase();
    const cards = document.querySelectorAll('#emsGrid .ems-card');
    let visible = 0;

    cards.forEach((card) => {
      const nom = card.getAttribute('data-nom') || '';
      const prenom = card.getAttribute('data-prenom') || '';
      const match = nom.includes(term) || prenom.includes(term);
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    const count = document.getElementById('count');
    if (count) count.textContent = `${visible} personne(s)`;
  });
}

// Edit toggle
for (const btn of document.querySelectorAll('[data-edit]')) {
  btn.addEventListener('click', () => {
    const id = btn.getAttribute('data-edit');
    const form = document.querySelector(`[data-edit-form="${id}"]`);
    if (form) form.classList.toggle('is-open');
  });
}
</script>

</body></html>
